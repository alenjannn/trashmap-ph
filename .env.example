# Copy to `.env.local` (local dev) and paste each into Vercel project Environment Variables (Production + Preview).

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Legacy JWT (eyJ...) NOT sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=

# === LGU dashboard server-side login ===
# Must match a seeded auth user with admin role (see supabase/schema.sql).
LGU_SUPABASE_AUTH_EMAIL=
LGU_SUPABASE_AUTH_PASSWORD=

# === OpenRouteService ===
ORS_API_KEY=

# === Server-only secrets (random strings) ===
# Used by manual + scheduled optimizer endpoints.
OPTIMIZER_CRON_SECRET=
# Vercel cron auth — set to the SAME value as OPTIMIZER_CRON_SECRET when
# deploying with vercel.json crons. Vercel auto-sends `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=
# Demo seed endpoints (POST /api/demo/dayN-seed).
DEMO_SEED_SECRET=
# Route ops token for dashboard write actions (assign, materialize, delete).
ROUTE_OPS_SECRET=
